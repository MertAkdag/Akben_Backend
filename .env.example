# Story API — örnek ortam değişkenleri
# Kopyalayıp `.env` olarak kaydedin (`cp .env.example .env`)

# Prisma Migrate / CLI (prisma.config.ts) — `prisma+postgres://` olabilir
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/story_db?schema=public"

# Uygulama (pg adapter) — mutlaka postgresql:// olmalı.
# DATABASE_URL prisma+ ise aşağıdakilerden BİRİNİ doldurun:
POSTGRES_DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/story_db?schema=public"
# Alternatif isimler (biri yeterli): DIRECT_URL veya POSTGRES_URL
# DIRECT_URL="postgresql://..."

PORT=3001
NODE_ENV=development

# JWT (auth backend ile aynı secret veya public key)
JWT_SECRET="change-me-use-long-random-string"
# RS256 için JWT_PUBLIC_KEY yerine (veya ek olarak) PEM, satırlar \n ile
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

JWT_USER_ID_CLAIM=userId
STORY_MEDIA_STORAGE_DIR="var/story-media"
STORY_MEDIA_TMP_DIR="var/story-media-tmp"
# Prod'da CDN veya origin media URL'i. Boş bırakırsanız request host/protocol kullanılır.
# STORY_MEDIA_PUBLIC_BASE_URL="https://stories-cdn.example.com/media"
STORY_MAX_UPLOAD_BYTES=262144000
STORY_IMAGE_FORMAT=webp
STORY_IMAGE_QUALITY=90
STORY_IMAGE_MAX_WIDTH=1080
STORY_THUMB_SIZE=320
STORY_VIDEO_MAX_SECONDS=60
STORY_VIDEO_OVERFLOW_POLICY=trim
STORY_HLS_SEGMENT_SECONDS=2
STORY_HLS_PREVIEW_SECONDS=3
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe
# JWT_ISSUER=
# JWT_AUDIENCE=
