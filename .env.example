# Story API — örnek ortam değişkenleri
# Kopyalayıp `.env` olarak kaydedin (`cp .env.example .env`)

# Prisma Migrate / CLI (prisma.config.ts) — `prisma+postgres://` olabilir
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/story_db?schema=public"

# Uygulama (pg adapter) — mutlaka postgresql:// olmalı.
# DATABASE_URL prisma+ ise aşağıdakilerden BİRİNİ doldurun:
POSTGRES_DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/story_db?schema=public"
# Alternatif isimler (biri yeterli): DIRECT_URL veya POSTGRES_URL
# DIRECT_URL="postgresql://..."

PORT=3001
NODE_ENV=development

# JWT (auth backend ile aynı secret veya public key)
JWT_SECRET="change-me-use-long-random-string"
# RS256 için JWT_PUBLIC_KEY yerine (veya ek olarak) PEM, satırlar \n ile
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

JWT_USER_ID_CLAIM=userId

# ── Push Notifications ──
# Admin (broadcast) yetkisi olan roller — virgülle ayrık. Boş: SUPER_ADMIN,ADMIN
# ADMIN_ROLES="SUPER_ADMIN,ADMIN"
# Expo Push erişim token'ı. Expo "Enhanced Security" açıksa ZORUNLU, değilse opsiyonel.
# https://expo.dev/accounts/[hesap]/settings/access-tokens
# EXPO_ACCESS_TOKEN=""

# ── WhatsApp (Meta Cloud API) ──
# Demo: panelden elle girilen numaralara ONAYLI template gönderir.
# İkisi de boşsa WhatsApp gönderimi atlanır (configured:false) — push etkilenmez.
# WHATSAPP_TOKEN ve WHATSAPP_PHONE_NUMBER_ID Meta App Dashboard > WhatsApp > API Setup'tan.
# WHATSAPP_TOKEN=""                 # System User / kalıcı erişim token'ı (Bearer)
# WHATSAPP_PHONE_NUMBER_ID=""       # Gönderen numaranın Phone Number ID'si (telefon no DEĞİL)
# WHATSAPP_GRAPH_VERSION="v21.0"    # opsiyonel — Graph API sürümü

# ── Admin paneli (Akben_Admin) ──
# Ayarlanırsa panel build'i (dist/) backend tarafından aynı origin'den servis edilir.
# Mutlak yol veya backend cwd'sine göre göreli olabilir. Boşsa panel servis edilmez.
# ADMIN_DIST_DIR="../Akben_Admin/dist"

STORY_MEDIA_STORAGE_DIR="var/story-media"
STORY_MEDIA_TMP_DIR="var/story-media-tmp"
# Prod'da CDN veya origin media URL'i. Boş bırakırsanız request host/protocol kullanılır.
# HTTPS reverse proxy arkasında bunu sabitlemek en garantisi (story medya URL'leri https olsun):
# STORY_MEDIA_PUBLIC_BASE_URL="https://panel.akben.com/media"
STORY_MAX_UPLOAD_BYTES=262144000
STORY_IMAGE_FORMAT=webp
STORY_IMAGE_QUALITY=90
STORY_IMAGE_MAX_WIDTH=1080
STORY_THUMB_SIZE=320
STORY_VIDEO_MAX_SECONDS=60
STORY_VIDEO_OVERFLOW_POLICY=trim
STORY_HLS_SEGMENT_SECONDS=2
STORY_HLS_PREVIEW_SECONDS=3
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe
# JWT_ISSUER=
# JWT_AUDIENCE=

# ── Story Broadcast (çok-kanallı yayın) ──
# Her broadcast kendi in-app grubunu oluşturur; grup adı/avatarı verilmezse bunlar kullanılır.
STORY_BRAND_NAME="Akben"
# STORY_BRAND_AVATAR_URL="https://cdn.example.com/brand/akben-avatar.png"
# Worker (Postgres job kuyruğu) ayarları:
STORY_BROADCAST_WORKER_INTERVAL_MS=15000   # job kuyruğu tarama aralığı
STORY_BROADCAST_WORKER_BATCH=5             # bir tick'te işlenecek max job
STORY_BROADCAST_RETRY_BASE_SECONDS=30      # retry backoff tabanı (base * 2^(deneme-1))

# ── Instagram (Meta Graph API — Stories content publishing) ──
# İkisi de boşsa instagram kanalı "skipped" işaretlenir (kod hazır, creds gelince aktifleşir).
# Gereksinim: FB Page'e bağlı Instagram Business/Creator hesabı.
# INSTAGRAM_ACCESS_TOKEN=""              # uzun ömürlü Page/System User token'ı
# INSTAGRAM_BUSINESS_ACCOUNT_ID=""       # IG Business hesabının ID'si
# INSTAGRAM_GRAPH_VERSION="v21.0"        # opsiyonel
# INSTAGRAM_PUBLISH_POLL_TIMEOUT_MS=120000   # video container işleme bekleme süresi
# INSTAGRAM_PUBLISH_POLL_INTERVAL_MS=3000    # polling aralığı
