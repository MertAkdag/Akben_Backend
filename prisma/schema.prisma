generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StoryGroupType {
  brand
  user
}

enum MediaType {
  image
  video
}

enum CtaType {
  product
  collection
  link
  design
}

enum Platform {
  ios
  android
  web
}

model StoryGroup {
  id        String         @id @default(cuid())
  name      String
  avatarUrl String
  type      StoryGroupType
  priority  Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  stories   Story[]

  @@index([priority(sort: Desc), id])
}

model Story {
  id                    String      @id @default(cuid())
  groupId               String
  mediaUrl              String
  thumbnailUrl          String
  posterUrl             String?
  mediaType             MediaType
  durationMs            Int
  order                 Int
  createdAt             DateTime    @default(now())
  expiresAt             DateTime
  ctaType               CtaType?
  ctaValue              String?
  ctaLabel              String?
  originalMediaUrl      String?
  optimizedFormat       String?
  hlsManifestUrl        String?
  hlsPreviewSegmentUrls String[]    @default([])
  mediaBytes            Int?
  mediaWidth            Int?
  mediaHeight           Int?
  processedAt           DateTime?
  group                 StoryGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  views                 StoryView[]

  @@index([groupId, order])
  @@index([expiresAt])
}

model StoryView {
  userId       String
  storyId      String
  seenAt       DateTime
  completed    Boolean
  ctaClicked   Boolean
  ctaClickedAt DateTime?
  platform     Platform
  createdAt    DateTime  @default(now())
  story        Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([userId, storyId])
  @@index([storyId])
}

// ═══════════════════════════════════════════
// Story Broadcast (çok-kanallı yayın orkestrasyonu)
// ═══════════════════════════════════════════

// Yayın hedefi kanallar. inapp = mevcut story sistemi.
// instagram = Graph API content publishing. whatsapp = sonraki faz.
enum StoryChannel {
  inapp
  instagram
  whatsapp
}

// Bir broadcast'in toplam durumu (kanal job'larından roll-up edilir).
enum BroadcastStatus {
  scheduled // scheduledAt gelecekte — hiçbir job henüz çalışmadı
  processing // en az bir job pending/processing
  partial // bazı kanallar published, en az biri failed
  completed // tüm (skipped hariç) kanallar published
  failed // hiçbir kanal published edilemedi
}

// Tek bir kanal teslimatının durumu.
enum ChannelJobStatus {
  pending // kuyrukta — nextAttemptAt geldiğinde işlenecek
  processing // worker şu an çalıştırıyor
  published // başarıyla yayınlandı
  failed // maxAttempts tükendi
  skipped // kanal yapılandırılmamış (örn. Instagram creds yok)
}

// Tek bir admin yayın aksiyonu. Medya bir kez işlenir, tüm kanallar paylaşır.
model StoryBroadcast {
  id          String  @id @default(cuid())
  mediaType   MediaType
  // In-app birincil asset (image: webp/avif, video: HLS master)
  mediaUrl    String
  thumbnailUrl String
  posterUrl   String?
  optimizedFormat String?
  hlsManifestUrl String?
  hlsPreviewSegmentUrls String[] @default([])
  // Instagram-uyumlu rendition (image: JPEG, video: H.264/AAC MP4) — public URL.
  // Instagram hedefliyse zorunlu; HLS/webp IG'de çalışmaz.
  igMediaUrl  String?
  mediaBytes  Int?
  mediaWidth  Int?
  mediaHeight Int?
  durationMs  Int
  caption     String?
  // CTA — in-app story'ye geçer (IG story link sticker opsiyonel).
  ctaType     CtaType?
  ctaValue    String?
  ctaLabel    String?
  // Her broadcast kendi in-app grubunu oluşturur.
  groupName      String
  groupAvatarUrl String
  targetChannels StoryChannel[]
  expiresAt      DateTime // in-app story TTL
  scheduledAt    DateTime? // null = hemen yayınla
  status         BroadcastStatus @default(processing)
  createdBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  jobs           StoryChannelJob[]

  @@index([status, scheduledAt])
  @@index([createdAt])
}

// Kanal başına teslimat/iş kaydı. Retry ve durum takibinin kalbi.
model StoryChannelJob {
  id            String           @id @default(cuid())
  broadcastId   String
  channel       StoryChannel
  status        ChannelJobStatus @default(pending)
  attempts      Int              @default(0)
  maxAttempts   Int              @default(5)
  lastError     String?
  externalId    String? // IG media id / in-app story id
  nextAttemptAt DateTime? // backoff/scheduling zamanı (null = hemen)
  publishedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  broadcast     StoryBroadcast   @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, channel])
  @@index([status, nextAttemptAt])
}

// ═══════════════════════════════════════════
// Flash Deal
// ═══════════════════════════════════════════

enum DealStatus {
  scheduled
  active
  expired
  soldOut
  cancelled
}

enum DealType {
  daily
  flash
  weekend
}

enum FlashDealCtaType {
  product
  link
  whatsapp
}

enum FlashDealInteractionType {
  impression
  click
  claim
  share
}

model FlashDeal {
  id String @id @default(cuid())

  // ── Ürün ──
  title       String
  subtitle    String?
  description String?
  imageUrl    String
  imageUrls   String[]

  // ── Milyem Bazlı Fiyatlandırma ──
  originalMilyem  Decimal @db.Decimal(6, 2)
  dealMilyem      Decimal @db.Decimal(6, 2)
  discountPercent Decimal @db.Decimal(5, 2)

  // ── Stok ──
  totalStock     Int
  remainingStock Int

  // ── Zamanlama ──
  type     DealType   @default(daily)
  startsAt DateTime
  endsAt   DateTime
  status   DealStatus @default(scheduled)

  // ── Hedefleme ──
  targetTier String?
  priority   Int     @default(0)

  // ── İlişkili Ürün ──
  productId String?

  // ── CTA ──
  ctaLabel String           @default("Sepete Ekle")
  ctaType  FlashDealCtaType @default(product)
  ctaValue String?

  // ── Meta ──
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ── İlişkiler ──
  interactions FlashDealInteraction[]

  @@index([status, startsAt])
  @@index([endsAt])
  @@index([type, status])
  @@index([deletedAt])
}

model FlashDealInteraction {
  id        String                   @id @default(cuid())
  userId    String
  dealId    String
  type      FlashDealInteractionType
  platform  Platform
  createdAt DateTime                 @default(now())

  deal FlashDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, type])
  @@index([userId, dealId])
  @@index([createdAt])
  @@index([dealId, createdAt])
  @@index([userId, createdAt])
}

// ═══════════════════════════════════════════
// User Tier (B2B Wholesale Only — NO retail)
// ═══════════════════════════════════════════

enum UserTier {
  wholesale
  vip_wholesale
}

// ═══════════════════════════════════════════
// Homepage Section (Server-Driven Feed)
// ═══════════════════════════════════════════

model HomepageSection {
  id          String   @id @default(cuid())

  // ── Section identity ──
  sectionType String                     // "market_ticker", "story_row", "editorial_hero", etc.
  title       String?
  subtitle    String?
  layoutVariant String @default("default") // "default", "compact", "editorial", "hero"

  // ── Display config ──
  priority    Int     @default(0)          // Higher = shown first
  enabled     Boolean @default(true)
  backgroundColor String?

  // ── Visibility rules ──
  startDate   DateTime?
  endDate     DateTime?
  targetTiers String[] @default([])        // ["vip_wholesale","wholesale"] — empty = all
  platforms   String[] @default([])        // ["ios","android"] — empty = all
  minAppVersion String?

  // ── Data resolution ──
  dataConfig  Json    @default("{}")       // Section-specific config (e.g., product IDs, collection ID)

  // ── Meta ──
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled, priority(sort: Desc)])
  @@index([sectionType])
}

// ═══════════════════════════════════════════
// Category Overlay (Visual Enrichment Layer)
// ═══════════════════════════════════════════

model CategoryOverlay {
  id             String   @id @default(cuid())
  categoryId     Int      @unique            // ERP'deki kategori ID
  imageUrl       String?                     // Banner görseli
  bannerTitle    String?                     // "Geleneksel dokunuşun modern yorumu"
  bannerSubtitle String?
  displayOrder   Int      @default(0)
  featured       Boolean  @default(false)    // Katalog ana sayfasında göster
  ctaLabel       String?  @default("KEŞFET")
  ctaStyle       String?  @default("primary") // "primary" | "outline"
  aspectRatio    String?  @default("3:4")     // Kart aspect ratio: "3:4", "1:1", "4:5", "16:9"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([featured, displayOrder(sort: Desc)])
}

// ═══════════════════════════════════════════
// Inquiry (Replaces Cart-Based Checkout)
// ═══════════════════════════════════════════

enum InquiryType {
  price_request
  availability
  custom_order
  wholesale_bulk
  general
}

enum InquiryStatus {
  pending
  assigned
  responded
  closed
}

model Inquiry {
  id              String        @id @default(cuid())
  userId          String
  productId       String?
  productName     String?

  type            InquiryType   @default(general)
  status          InquiryStatus @default(pending)
  message         String?
  quantity        Int?
  preferredContact String      @default("whatsapp")  // whatsapp | phone | email | in_app
  urgency         String        @default("standard")  // standard | urgent

  // ── CRM Assignment ──
  assignedRepId   String?
  respondedAt     DateTime?

  // ── Meta ──
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([assignedRepId])
}

// ═══════════════════════════════════════════
// User Event (Analytics Pipeline)
// ═══════════════════════════════════════════

model UserEvent {
  id        String   @id @default(cuid())
  userId    String
  eventType String                        // "product_view", "inquiry", "add_to_order", "section_impression"
  metadata  Json     @default("{}")       // { productId, sectionType, quantity, etc. }
  platform  Platform
  createdAt DateTime @default(now())

  @@index([userId, eventType])
  @@index([eventType, createdAt])
  @@index([createdAt])
}

// ═══════════════════════════════════════════
// Push Notifications (Expo Push)
// ═══════════════════════════════════════════

// Mobil tarafındaki 4 bildirim tipiyle birebir (app/notifications.tsx)
enum NotificationType {
  CAMPAIGN
  ORDER
  PRICE
  SYSTEM
}

enum CampaignStatus {
  draft
  sending
  sent
  failed
}

// Bir kullanıcının cihazı = bir Expo push token.
// userId DAİMA doğrulanmış token'dan (req.userId) gelir, body'den DEĞİL.
model Device {
  id            String    @id @default(cuid())
  userId        String
  expoPushToken String    @unique           // "ExponentPushToken[...]"
  platform      Platform
  // tier client-supplied (JWT'de tier claim'i yok — feed meta'sından gelir). Demo: broadcast hedefleme için saklanır.
  tier          String?                      // "wholesale" | "vip_wholesale"
  appVersion    String?
  locale        String?
  deviceName    String?
  lastSeenAt    DateTime  @default(now())
  disabledAt    DateTime?                    // Expo "DeviceNotRegistered" -> burada işaretlenir (prune)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([tier])
  @@index([disabledAt])
}

// Kullanıcı başına bildirim tercihleri. Mobil settings ekranını sunucuya bağlar.
model NotificationPreference {
  userId    String   @id
  campaigns Boolean  @default(true)
  orders    Boolean  @default(true)
  prices    Boolean  @default(true)
  system    Boolean  @default(true)
  email     Boolean  @default(false)
  sms       Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Inbox kaydı (kullanıcı başına). Mobil notification center'ı mock'tan kurtarır.
model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType @default(SYSTEM)
  title      String
  body       String
  data       Json             @default("{}")  // { entityId, ... } — deep-link payload
  deepLink   String?                           // "akben://..." veya route
  campaignId String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  campaign NotificationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@index([campaignId])
}

// Admin broadcast. v1: segment yok, tier/platform filtresi opsiyonel (boş = herkes).
model NotificationCampaign {
  id              String           @id @default(cuid())
  title           String
  body            String
  type            NotificationType @default(CAMPAIGN)
  data            Json             @default("{}")
  deepLink        String?
  targetTiers     String[]         @default([])  // boş = tüm tier'lar
  targetPlatforms String[]         @default([])  // boş = tüm platformlar
  status          CampaignStatus   @default(draft)
  audienceCount   Int              @default(0)
  sentCount       Int              @default(0)
  failedCount     Int              @default(0)
  createdBy       String?                         // gönderen admin userId
  sentAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  notifications Notification[]

  @@index([status, createdAt(sort: Desc)])
}
